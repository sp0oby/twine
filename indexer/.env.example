# Copy to .env.local and fill in. Never commit the real .env.

# RPC endpoints
PONDER_RPC_URL_BASE=https://mainnet.base.org
PONDER_RPC_URL_BASE_SEPOLIA=https://sepolia.base.org

# Twine contract addresses (from script/Deploy.s.sol + script/CreatePool.s.sol)
PONDER_HOOK_ADDRESS=
PONDER_PM_ADDRESS=
PONDER_VAULT_ADDRESS=

# Earliest block the indexer should scan from (the block the contracts were deployed in)
PONDER_START_BLOCK=

# Ponder's local API port (default 42069)
PORT=42069

# Copy to .env.local and fill in. Never commit the real .env.local.

# WalletConnect project id (cloud.walletconnect.com). Optional - RainbowKit still works
# with injected/browser wallets if this isn't set, just without WC modal support.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional: explicit indexer URL the dashboard reads from (defaults to the local ponder dev server).
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069

# Optional dedicated RPCs. Without these we fall back to the public Base node, which works for
# basic reads but rate-limits and clamps `eth_getLogs` ranges - the z-score and recent-swaps
# panels need a real RPC (Alchemy / QuickNode / Infura) to scan ~150k blocks reliably.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Copy to .env and fill in. NEVER commit the real .env.
# RPC endpoints (used by foundry.toml [rpc_endpoints] and fork tests)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer — prefer a keystore/hardware signer over a raw key.
# For local/anvil only. Do NOT put a funded mainnet key here.
DEPLOYER_PRIVATE_KEY=

# Etherscan/Basescan API key for contract verification
BASESCAN_API_KEY=

# Verified Base cbBTC/USD Chainlink feed (8 decimals). Set this in .env to enable the
# adapter fork test (test/fork). Leave unset to skip it (e.g. in CI without a Base RPC).
BASE_CBBTC_USD_FEED=0x07DA0E54543a844a80ABE69c8A12F22B3aA59f9D
